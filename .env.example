# ============================================================
# 银发矩阵系统 - 环境变量配置
# 复制本文件为 .env 并填入真实密钥
# ============================================================

# 【AI 视频/图像生成配置】
ZHIPU_API_KEY=your-zhipu-api-key-here

# --- LLM：故事评分 & 文案改写 ---
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

SCRIPT_API_KEY=your-script-llm-key-here
SCRIPT_BASE_URL=https://api.openai.com/v1
SCRIPT_MODEL=gpt-4o-mini

# --- TTS 后端选择 ---
# edge    = 微软合成音（默认，开箱即用，但机器味重）
# minimax = MiniMax 海螺语音（云端，推荐：中文情感好，Intel mac 无障碍，无需 torch）
# f5      = F5-TTS 本地克隆音（需 torch+GPU，Intel mac 不实用）
TTS_BACKEND=edge

# --- MiniMax 海螺语音（TTS_BACKEND=minimax 时生效）---
MINIMAX_API_KEY=your-minimax-key
MINIMAX_GROUP_ID=your-minimax-group-id     # 必填！MiniMax 控制台 → 账户信息里的 GroupID
MINIMAX_MODEL=speech-01-turbo
MINIMAX_VOICE_FEMALE=Chinese (Mandarin)_Wise_Women   # 老年智慧女声（已验证）
MINIMAX_VOICE_MALE=Chinese (Mandarin)_Gentleman      # 男声占位，去控制台查可用 voice_id 替换
MINIMAX_SPEED=1.0
MINIMAX_PITCH=0

# --- F5 本地克隆音参数（TTS_BACKEND=f5 时生效）---
F5_PITCH_STEPS=2.5        # 升调半音数，0=不变调；参考音偏老沉时可调高让声音更清亮

# --- edge-tts 音色（TTS_BACKEND=edge，或 F5 失败兜底时使用）---
TTS_VOICE_MODEL=zh-CN-YunjianNeural          # 男声（旁白默认）
TTS_VOICE_MODEL_FEMALE=zh-CN-liaoning-XiaobeiNeural  # 女声
TTS_SPEECH_RATE=-10%
TTS_PITCH=-10Hz

# --- 路径 ---
ASSETS_DIR=assets
OUTPUT_DIR=output

# --- 视频设置 ---
FONT_PATH=Arial-Unicode-MS

# --- 变现阶段（控制评论区软引流强度，按账号成长阶段切换）---
# 0=起号期：纯互动不引流（默认，先养号攒信任）  1=起量期：带软引流  2=变现期：明确承接
MONETIZE_STAGE=0

# --- 视频号数据回传（微信开放平台，可选）---
WEIXIN_APPID=
WEIXIN_SECRET=

# --- 告警推送（企业微信 Webhook，可选）---
WECOM_WEBHOOK_URL=

# --- 代理池（可选，多个用逗号分隔）---
PROXY_LIST=

# --- RPA 调试（=1 时保存视频号页面源码/截图）---
CHANNELS_RPA_DEBUG=
